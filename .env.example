# Copy this file to ".env" (which is gitignored) and fill in your key to enable
# the LLM-powered "Ask the Data" chat. Without it, chat uses the offline parser.
#
#   cp .env.example .env
#   # edit .env, then:  docker compose up -d storefront
#
# OpenAI
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
